# Dependencies
node_modules/

# Build output
app/dist/
infra/cdk.out/
*.tsbuildinfo

# Lambda layer build artifacts (wheels) — rebuilt from requirements.txt by build.sh / CI
infra/layers/*/build/

# Python bytecode caches
__pycache__/
*.pyc

# Secrets & local env — NEVER commit these
.env*
!.env.example
*.pem
.aws/
.aws/iam/   # local-only IAM trust/permission policy JSONs for the CI OIDC role

# CDK context (can cache account id / VPC lookup data)
cdk.context.json

# Logs / OS junk
*.log
.DS_Store
Thumbs.db
