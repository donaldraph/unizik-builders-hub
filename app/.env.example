# Copy this file to .env.local and fill in the values from your `cdk deploy --all` outputs.
# These four are the only wiring between the app and your AWS backend.

# From the api stack output (ApiUrl) — include the trailing slash
VITE_API_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com/dev/

# From the auth stack output (LoginDomain) — the full https URL of the Cognito domain
VITE_COGNITO_DOMAIN=https://asbu-dev-REPLACE_ME.auth.us-east-1.amazoncognito.com

# From the auth stack output (UserPoolClientId)
VITE_USER_POOL_CLIENT_ID=REPLACE_ME

# From the auth stack output (UserPoolId) — needed by the custom auth screens
# that talk to Cognito directly (sign-up, verify, sign-in, forgot-password).
VITE_USER_POOL_ID=us-east-1_REPLACE_ME
VITE_AWS_REGION=us-east-1

# Where Cognito redirects back after login. Local dev default shown.
# In prod set this to https://aws.unizikbuilders.tech/callback
VITE_REDIRECT_URI=http://localhost:5173/callback
